{
    "installCommand": "pnpm install --no-frozen-lockfile",
    "buildCommand": "pnpm run build:client",
    "outputDirectory": "dist/spa",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://pharmai-api-production-5229.up.railway.app/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}